# Daemons configuration for FRR
# This file tells FRR which routing daemons to run

bgpd=yes
ospfd=no
ospf6d=no

# RPKI Option
ripd=no
ripngd=no
isisd=no
pimd=no
ldpd=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
pbrd=no
bfdd=no
fabricd=no
vrrpd=no

# Integrated config (all in one frr.conf file)
vtysh_enable=yes
zebra_options=" -A 127.0.0.1 -s 90000000"
bgpd_options=" -A 127.0.0.1 -M rpki"
